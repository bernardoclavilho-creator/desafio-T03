programa  
{  
    funcao inicio()  
    {  
                        
        inteiro num  
  
        escreva ("Digite o numero: ")  
        leia (num)  
          
        se (num %2==0)  
        {  
            escreva ("par")  
        }  
        senao  
        {  
            escreva ("impar")  
        }  
          
    }  
}  